# Use one provider. If both keys are set, defaults to Anthropic unless LLM_PROVIDER=openai.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: anthropic | openai (auto-picks OpenAI when only OPENAI_API_KEY is set)
# LLM_PROVIDER=openai

# Optional override (defaults: claude-sonnet-4-20250514 / gpt-4o-mini)
# LLM_MODEL=gpt-4o

# Optional: JS Global web trading (wt.jsglobalonline.com) — tools/js_global.py
# Prefer: `pip install playwright && playwright install chromium` then `python3 -m tools.js_global login`
# Optional override path for saved session (default: .cache/js_global_storage.json)
# JS_GLOBAL_STORAGE=/path/to/storage.json
# Or paste Cookie header into a one-line file (handles JSON quotes in cookies):
# JS_GLOBAL_COOKIE_FILE=.cache/js_global_cookie.txt
# JS_GLOBAL_ACCOUNT=12345
